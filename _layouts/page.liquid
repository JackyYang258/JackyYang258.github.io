---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
    {% if page.author %}
      <p style="text-align: center; font-size: 1.25rem; margin-top: 0.4rem; margin-bottom: 0.8rem;">
        {% assign author_entries = page.author | split: ';' %}
        {% for author_entry in author_entries %}
          {% assign author_parts = author_entry | split: ',' %}
          {% assign author_name = author_parts[0] | strip %}
          {% assign author_url = author_parts[1] | strip %}
          {% if author_url and author_url != '' %}
            <a href="{{ author_url }}">{{ author_name }}</a>
          {% else %}
            {{ author_name }}
          {% endif %}
          {% unless forloop.last %}, {% endunless %}
        {% endfor %}
      </p>
    {% endif %}
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
